@model CitasApp.Models.Medico

@{
    ViewData["Title"] = "Agregar Médico";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Agregar Médico</h1>
        <a asp-action="Index" class="btn btn-secondary">← Volver al listado</a>
    </div>

    <div class="card shadow-sm" style="max-width: 540px;">
        <div class="card-body">
            <form asp-action="Crear" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nombre</label>
                    <input asp-for="Name" class="form-control" placeholder="Ej. Luis" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Apellido" class="form-label">Apellido</label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ej. Martínez" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Especialidad" class="form-label">Especialidad</label>
                    <input asp-for="Especialidad" class="form-control" placeholder="Ej. Cardiología" />
                    <span asp-validation-for="Especialidad" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NumeroLicencia" class="form-label">Número de Licencia</label>
                    <input asp-for="NumeroLicencia" class="form-control" placeholder="Ej. LIC-12345" />
                    <span asp-validation-for="NumeroLicencia" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100">Guardar Médico</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
