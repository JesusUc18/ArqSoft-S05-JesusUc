@model IEnumerable<CitasApp.Domain.Models.Medico>

@{
    ViewData["Title"] = "Listado de Médicos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Médicos Disponibles</h1>
        <a asp-action="Crear" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Agregar Médico
        </a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Médico</th>
                <th>Especialidad</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var medico in Model)
            {
                <tr>
                    <td>@medico.Id</td>
                    <td>Dr(a). @medico.Name @medico.Apellido</td>
                    <td><span class="badge bg-success">@medico.Especialidad</span></td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@medico.Id" class="btn btn-info btn-sm">Ver Detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
