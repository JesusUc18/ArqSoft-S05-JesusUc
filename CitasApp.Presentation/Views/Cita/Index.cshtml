@model IEnumerable<CitasApp.Models.Cita>

@{
    ViewData["Title"] = "Agenda de Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Agenda Completa de Citas</h1>
        <a asp-action="Crear" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Agendar Cita
        </a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-primary">
            <tr>
                <th>ID Cita</th>
                <th>ID Paciente</th>
                <th>ID Médico</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Motivo</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cita in Model)
            {
                <tr>
                    <td>@cita.Id</td>
                    <td>@cita.PacienteId</td>
                    <td>@cita.MedicoId</td>
                    <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                    <td>@cita.Hora.ToString("hh:mm tt")</td>
                    <td>@cita.Motivo</td>
                    <td>
                        @if (cita.Estado == "Confirmada")
                        {
                            <span class="badge bg-success">@cita.Estado</span>
                        }
                        else if (cita.Estado == "Pendiente")
                        {
                            <span class="badge bg-warning text-dark">@cita.Estado</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@cita.Estado</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
